{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_instructions": "Copy this file to settings.local.json (gitignored) and fill in per-machine secrets. Do NOT commit settings.local.json.",
  "mcpServers": {
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server@2.2.1"],
      "env": {
        "NOTION_TOKEN": "YOUR_NOTION_INTEGRATION_TOKEN"
      }
    },
    "notebooklm": {
      "command": "notebooklm-mcp",
      "args": ["--stdio"],
      "env": {
        "_note": "Install via: uv tool install notebooklm-mcp-cli && nlm login && nlm setup add claude-code. If unavailable on this machine, set CLAWSPACE_NOTEBOOKLM_MODE=manual and the notebooklm-bridge agent will fall back to staging-only mode."
      }
    },
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "YOUR_EXA_API_KEY"
      }
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "YOUR_FIRECRAWL_API_KEY"
      }
    },
    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp@0.1.4"],
      "env": {
        "TAVILY_API_KEY": "YOUR_TAVILY_API_KEY"
      }
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@anthropic/brave-search-mcp"],
      "env": {
        "BRAVE_API_KEY": "YOUR_BRAVE_SEARCH_API_KEY"
      }
    },
    "youtube-transcript": {
      "command": "npx",
      "args": ["-y", "youtube-transcript-mcp"]
    },
    "arxiv": {
      "command": "npx",
      "args": ["-y", "arxiv-mcp-server"]
    },
    "perplexity": {
      "command": "npx",
      "args": ["-y", "perplexity-mcp"],
      "env": {
        "PERPLEXITY_API_KEY": "YOUR_PERPLEXITY_API_KEY"
      }
    },
    "reddit": {
      "command": "npx",
      "args": ["-y", "reddit-mcp-server"],
      "env": {
        "REDDIT_CLIENT_ID": "YOUR_REDDIT_CLIENT_ID",
        "REDDIT_CLIENT_SECRET": "YOUR_REDDIT_CLIENT_SECRET"
      }
    }
  },
  "env": {
    "CLAWSPACE_NOTEBOOKLM_MODE": "auto",
    "CLAWSPACE_NOTION_DB_CONTENT": "<notion-database-id-for-content-queue>",
    "CLAWSPACE_NOTION_DB_RESEARCH": "<notion-database-id-for-research-digests>",
    "CLAWSPACE_NOTION_DB_CALENDAR": "<notion-database-id-for-content-calendar>",
    "CLAWSPACE_NOTION_DB_SOURCES": "<notion-database-id-for-source-library>",
    "CLAWSPACE_NOTION_DB_NEWSLETTER": "<notion-database-id-for-newsletter-archive>",
    "CLAWSPACE_NOTION_DB_IDEAS": "<notion-database-id-for-ideas-board>"
  }
}
